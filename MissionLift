/* ── STATE ── */
var DAYS;
var activeSec="workout";
var activeDay="A";
var activePump="arms";
var activeCore="all";
var activeLib=null;
var modalDay=null;
var detPanels={};
var logPanels={};
var roDetPanels={};

function initDays(){
  var saved=store.get("lift_days_v6");
  if(saved&&Array.isArray(saved)&&saved.length===DEFAULT_DAYS.length){DAYS=saved;}
  else{DAYS=JSON.parse(JSON.stringify(DEFAULT_DAYS));}
}
function saveDays(){store.set("lift_days_v6",DAYS);}
function getLogs(){var l=store.get("lift_logs_v6");return Array.isArray(l)?l:[];}
function saveLogs(l){store.set("lift_logs_v6",l.slice(0,400));}
function getCI(){return store.get("lift_ci_v3")||{};}
function saveCI(o){store.set("lift_ci_v3",o);}
function getWLog(){return store.get("lift_wlog_v1")||{};}
function saveWLog(o){store.set("lift_wlog_v1",o);}
function logWeight(w){
  var wlog=getWLog();
  var key=new Date().toDateString();
  if(w&&parseFloat(w)>0){wlog[key]=parseFloat(w);}
  else{delete wlog[key];}
  saveWLog(wlog);
}
function getDraft(id){return store.sget("lift_draft_"+id)||{};}
function getDayById(id){for(var i=0;i<DAYS.length;i++){if(DAYS[i].id===id)return DAYS[i];}return null;}

function saveDraft(dayId){
  var day=getDayById(dayId);if(!day)return;
  var data={};
  day.exercises.forEach(function(ex,i){
    data[i]={};
    for(var s=1;s<=ex.sets;s++){
      var w=document.getElementById("w_"+dayId+"_"+i+"_"+s);
      var r=document.getElementById("r_"+dayId+"_"+i+"_"+s);
      var rpe=document.getElementById("rpe_"+dayId+"_"+i+"_"+s);
      var n=document.getElementById("n_"+dayId+"_"+i+"_"+s);
      data[i][s]={w:w?w.value:"",r:r?r.value:"",rpe:rpe?rpe.value:"",n:n?n.value:""};
    }
  });
  store.sset("lift_draft_"+dayId,data);
}

/* ── INIT ── */
function init(){
  initTheme();initDays();initClock();initStreak();initQuote();initCI();
  renderDayTabs();renderDay("A");renderPump();renderCore();renderLibrary();
}

function initClock(){
  function tick(){
    var n=new Date();
    var c=document.getElementById("clock");
    var d=document.getElementById("date-str");
    if(c)c.textContent=n.toLocaleTimeString("en-US",{hour:"2-digit",minute:"2-digit",second:"2-digit",hour12:true});
    if(d)d.textContent=n.toLocaleDateString("en-US",{weekday:"short",month:"short",day:"numeric"});
  }
  tick();setInterval(tick,1000);
}

function initStreak(){
  var logs=getLogs();
  var worked={};
  logs.forEach(function(l){if(l.ts)worked[new Date(l.ts).toDateString()]=true;});
  var container=document.getElementById("sdots");if(!container)return;
  container.innerHTML="";
  var dayNames=["Su","Mo","Tu","We","Th","Fr","Sa"];
  var streak=0;
  for(var i=13;i>=0;i--){
    var d=new Date();d.setDate(d.getDate()-i);
    var done=!!worked[d.toDateString()];
    var isToday=(i===0);
    if(done)streak++;else if(i>0)streak=0;
    var wrap=document.createElement("div");wrap.className="sdot-wrap";
    var dot=document.createElement("div");
    dot.className="sdot"+(done?" done":"")+(isToday&&!done?" today-e":"");
    dot.title=d.toLocaleDateString("en-US",{month:"short",day:"numeric"})+(done?" \u2713":"");
    var lbl=document.createElement("div");lbl.className="sdot-day";
    lbl.textContent=dayNames[d.getDay()];
    wrap.appendChild(dot);wrap.appendChild(lbl);container.appendChild(wrap);
  }
  var sc=document.getElementById("streak-count");
  if(sc){
    if(streak>0){sc.textContent=streak+" day"+(streak>1?"s":"")+(streak>=7?" \uD83C\uDF1F":" \uD83D\uDD25");sc.style.color=streak>=7?"var(--star)":"var(--aurora2)";}
    else{sc.textContent="Start today \uD83D\uDE80";sc.style.color="var(--void)";}
  }
}

function initQuote(){
  var idx=Math.floor(Date.now()/86400000)%QUOTES.length;
  var q=QUOTES[idx];
  var el=document.getElementById("quote");
  if(el)el.innerHTML="\u201c"+escHtml(q[0])+"\u201d &mdash; <strong>"+escHtml(q[1])+"</strong>";
}

function initCI(){
  var ci=getCI();
  var today=new Date().toDateString();
  if(ci.date===today){
    var wEl=document.getElementById("ci-w");
    if(wEl&&ci.w)wEl.value=ci.w;
    if(ci.m){document.querySelectorAll(".mbtn").forEach(function(b){if(b.getAttribute("data-m")===ci.m)b.classList.add("on");});}
  }
  var wInput=document.getElementById("ci-w");
  if(wInput)wInput.addEventListener("input",persistCI);
  document.querySelectorAll(".mbtn").forEach(function(b){
    b.addEventListener("click",function(){
      document.querySelectorAll(".mbtn").forEach(function(x){x.classList.remove("on");});
      b.classList.add("on");persistCI();
    });
  });
}

function persistCI(){
  var wEl=document.getElementById("ci-w");
  var mEl=document.querySelector(".mbtn.on");
  var w=wEl?wEl.value:"";
  saveCI({date:new Date().toDateString(),w:w,m:mEl?mEl.getAttribute("data-m"):""});
  logWeight(w);
}

/* ── NAV ── */
function goSec(s){
  activeSec=s;
  ["workout","pump","core","lib","history"].forEach(function(x){
    var sec=document.getElementById("sec-"+x);
