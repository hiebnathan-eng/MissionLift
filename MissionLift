  el.innerHTML=DAYS.map(function(d){
    return '<button class="dtab'+(d.id===activeDay?' on':'')+'" id="dt-'+d.id+'" onclick="selectDay(this.dataset.did)" data-did="'+d.id+'"><span>'+escHtml(d.label)+'</span><span class="dtype">'+escHtml(d.type)+'</span></button>';
