/* ── INPUT HANDLER ── */
function onInput(dayId,exIdx,k){
  saveDraft(dayId);
  var day=getDayById(dayId);if(!day)return;
  var ex=day.exercises[exIdx];if(!ex)return;
  var hasData=false;
  for(var s=1;s<=ex.sets;s++){
    var wEl=document.getElementById("w_"+dayId+"_"+exIdx+"_"+s);
    var rEl=document.getElementById("r_"+dayId+"_"+exIdx+"_"+s);
    if(wEl)wEl.classList.toggle("fl",!!wEl.value);
    if(rEl)rEl.classList.toggle("fl",!!rEl.value);
    if((wEl&&wEl.value)||(rEl&&rEl.value))hasData=true;
  }
  var btn=document.getElementById("logbtn_"+k);
  if(btn&&!logPanels[k]){
    if(hasData){btn.className="log-btn has-data";btn.innerHTML=checkSVG()+"\u2713 Logged";}
    else{btn.className="log-btn";btn.innerHTML=editSVG()+"Log sets";}
  }
}

