<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0a0e1a">
<title>LIFT — Mission Control</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{
  /* ── v0 Liquid Glass — Vivid Dark (default) ── */
  --space:#0b0f20;        /* page bg */
  --nebula:#181d33;       /* card/header surface */
  --cosmos:#202745;       /* secondary surface */
  --stardust:#2b3358;     /* input fields */
  --ink:#f4f6ff;          /* primary text */
  --ink2:#aeb7e0;         /* secondary text */
  --ink3:#7681ad;         /* tertiary text */
  --border:rgba(255,255,255,.14);
  --border2:rgba(255,255,255,.28);
  /* Categorical accents */
  --star:#ffd338;     --star-t:rgba(255,211,56,.14);
  --nova:#ff9248;     --nova-t:rgba(255,146,72,.14);
  --pulsar:#bb93ff;   --pulsar-t:rgba(187,147,255,.14);
  --quasar:#33dbf2;   --quasar-t:rgba(51,219,242,.14);
  --nebula2:#ff79c4;  --nebula2-t:rgba(255,121,196,.14);
  --comet:#3df0d6;    --comet-t:rgba(61,240,214,.14);
  --aurora2:#3df0a8;  --aurora2-t:rgba(61,240,168,.16);
  --mars:#ff7d7d;     --mars-t:rgba(255,125,125,.14);
  --void:#8b9bff;     --void-t:rgba(139,155,255,.16);
  /* Liquid Glass material */
  --glass:rgba(40,48,78,.40);
  --glass-strong:rgba(20,25,44,.58);
  --glass-brd:rgba(255,255,255,.18);
  --glass-blur:saturate(2) blur(30px);
  --spec:linear-gradient(180deg,rgba(255,255,255,.08) 0%,transparent 30%,transparent 70%,rgba(255,255,255,.02) 100%);
  --glass-sh:inset 0 1px 0 rgba(255,255,255,.12),0 8px 32px rgba(0,0,0,.35),0 2px 8px rgba(0,0,0,.25);
  --hairline:rgba(255,255,255,.16);
  /* Typography */
  --disp:'Space Grotesk','Inter',system-ui,sans-serif;
  --font:'Inter',system-ui,sans-serif;
  --mono:'JetBrains Mono','SF Mono',monospace;
  /* Shape */
  --r:24px;--r2:18px;--r3:13px;
  --ease:cubic-bezier(.34,1.2,.46,1);
  --bounce:cubic-bezier(.34,1.56,.64,1);
  --sh:0 4px 16px rgba(0,0,0,.35),0 1px 3px rgba(0,0,0,.25);
  --sh2:0 10px 36px rgba(0,0,0,.5),0 4px 12px rgba(0,0,0,.3);
  --glow:0 0 32px rgba(139,155,255,.35);
}

/* ═══ LIGHT MODE THEME ═══ */
[data-theme="light"]{
  /* ── v0 Liquid Glass — Bright theme ── */
  --space:#eef1f8;
  --nebula:#ffffff;
  --cosmos:#f3f6fc;
  --stardust:#e8edf7;
  --ink:#0c1020;
  --ink2:#525c79;
  --ink3:#8189a6;
  --border:rgba(18,22,45,.10);
  --border2:rgba(18,22,45,.22);
  --star:#e08400;     --star-t:rgba(224,132,0,.12);
  --nova:#ef5a18;     --nova-t:rgba(239,90,24,.12);
  --pulsar:#7c3aed;   --pulsar-t:rgba(124,58,237,.10);
  --quasar:#0891b2;   --quasar-t:rgba(8,145,178,.10);
  --nebula2:#e11d74;  --nebula2-t:rgba(225,29,116,.10);
  --comet:#0d9488;    --comet-t:rgba(13,148,136,.10);
  --aurora2:#059669;  --aurora2-t:rgba(5,150,105,.12);
  --mars:#dc2626;     --mars-t:rgba(220,38,38,.10);
  --void:#4f46e5;     --void-t:rgba(79,70,229,.12);
  --glass:rgba(255,255,255,.55);
  --glass-strong:rgba(255,255,255,.75);
  --glass-brd:rgba(18,22,45,.12);
  --glass-blur:saturate(1.6) blur(26px);
  --spec:linear-gradient(180deg,rgba(255,255,255,.4) 0%,transparent 40%);
  --glass-sh:inset 0 1px 0 rgba(255,255,255,.7),0 4px 16px rgba(18,22,45,.08),0 1px 3px rgba(18,22,45,.06);
  --hairline:rgba(18,22,45,.10);
  --sh:0 2px 8px rgba(18,22,45,.08),0 1px 2px rgba(18,22,45,.05);
  --sh2:0 8px 28px rgba(18,22,45,.14),0 2px 6px rgba(18,22,45,.08);
  --glow:0 0 24px rgba(79,70,229,.25);
}
/* Light mode: soften the starfield + aurora so they don't muddy the white */
[data-theme="light"] body{
  background-image:
    radial-gradient(ellipse at 20% 50%, rgba(79,70,229,.05) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 10%, rgba(147,51,234,.04) 0%, transparent 40%),
    radial-gradient(ellipse at 60% 90%, rgba(8,145,178,.03) 0%, transparent 40%);
}
[data-theme="light"] body::before{opacity:.12;}
[data-theme="light"] body::after{
  background:radial-gradient(ellipse at 50% 0%, rgba(79,70,229,.06), transparent 60%);
}
/* Light mode: header/nav glass needs a light tint instead of dark */
[data-theme="light"] .hdr{background:rgba(255,255,255,.85);}
[data-theme="light"] .bnav{background:rgba(255,255,255,.92);}
[data-theme="light"] .overlay{background:rgba(15,22,40,.45);}
/* Light mode: toast text stays dark-on-green readable */
[data-theme="light"] .toast{color:#ffffff;}
/* Light mode: chart canvas point centers use white→ use surface color via JS already (#0a0e1a) so override */

*{box-sizing:border-box;margin:0;padding:0;}
html{background:var(--space);min-height:100vh;}
body{font-family:var(--font);background:var(--space);color:var(--ink);-webkit-font-smoothing:antialiased;padding-bottom:84px;background-image:radial-gradient(ellipse at 20% 50%,rgba(99,102,241,.07) 0%,transparent 50%),radial-gradient(ellipse at 80% 10%,rgba(168,85,247,.05) 0%,transparent 40%),radial-gradient(ellipse at 60% 90%,rgba(6,182,212,.04) 0%,transparent 40%);}

.hdr{position:sticky;top:0;z-index:60;background:rgba(10,14,26,.93);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:13px 18px 11px;}
.hdr-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.logo{display:flex;align-items:center;gap:8px;}
.logo-icon{display:flex;align-items:center;filter:drop-shadow(0 0 8px rgba(250,204,21,.55));}
.logo-text{font-size:16px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;background:linear-gradient(135deg,var(--star),var(--nova));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.clock-wrap{text-align:right;}
.clock{font-family:var(--mono);font-size:16px;font-weight:600;color:var(--ink);letter-spacing:.05em;text-shadow:0 0 10px rgba(99,102,241,.4);}
.clock-sub{font-size:10px;color:var(--ink3);margin-top:1px;}
.streak-wrap{margin-bottom:9px;}
.streak-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.streak-lbl{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink3);}
.streak-count{font-size:12px;font-weight:800;}
.sdots{display:flex;gap:3px;overflow:hidden;}
.sdot-wrap{display:flex;flex-direction:column;align-items:center;gap:2px;flex:1;min-width:0;}
.sdot{width:100%;height:7px;border-radius:4px;background:var(--stardust);border:1px solid var(--border);transition:all .3s var(--ease);}
.sdot.done{background:var(--aurora2);border-color:var(--aurora2);box-shadow:0 0 6px rgba(52,211,153,.35);}
.sdot.today-e{background:rgba(99,102,241,.2);border:1.5px dashed var(--void);}
.sdot-day{font-size:7.5px;color:var(--ink3);font-weight:600;}
.quote{margin-bottom:9px;padding:9px 12px;background:linear-gradient(135deg,rgba(99,102,241,.08),rgba(168,85,247,.06));border:1px solid rgba(99,102,241,.2);border-radius:var(--r2);font-size:12px;color:var(--ink2);font-style:italic;line-height:1.55;}
.quote strong{color:var(--void);font-style:normal;font-weight:700;}
.ci-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.ci-block{background:var(--nebula);border:1px solid var(--border);border-radius:var(--r2);padding:8px 11px;box-shadow:var(--sh);}
.ci-lbl{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:3px;}
.ci-inp{background:transparent;border:none;outline:none;font-family:var(--font);font-size:15px;font-weight:700;color:var(--ink);width:100%;}
.ci-inp::placeholder{color:var(--ink3);font-weight:400;}
.mood-row{display:flex;gap:4px;margin-top:2px;}
.mbtn{background:var(--cosmos);border:1px solid var(--border);border-radius:7px;padding:3px 6px;font-size:13px;cursor:pointer;transition:all .15s;line-height:1.4;}
.mbtn:hover{border-color:var(--border2);}
.mbtn.on{background:var(--void-t);border-color:var(--void);box-shadow:0 0 8px rgba(99,102,241,.3);}
.dtabs-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding:0 18px;}
.dtabs-wrap::-webkit-scrollbar{display:none;}
.dtabs{display:flex;gap:7px;min-width:max-content;padding:11px 0 7px;}
.dtab{background:var(--nebula);border:1px solid var(--border);border-radius:var(--r2);padding:7px 16px;font-family:var(--font);font-size:13px;font-weight:700;color:var(--ink2);cursor:pointer;white-space:nowrap;transition:all .18s var(--ease);display:flex;flex-direction:column;align-items:center;gap:2px;box-shadow:var(--sh);}
.dtab .dtype{font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--ink3);transition:color .18s;}
.dtab:hover{border-color:var(--star);color:var(--ink);}
.dtab.on{background:linear-gradient(135deg,rgba(250,204,21,.15),rgba(249,115,22,.1));border-color:var(--star);color:var(--star);box-shadow:0 4px 16px rgba(250,204,21,.2);}
.dtab.on .dtype{color:var(--nova);}
.sec{display:none;}.sec.on{display:block;}
.eyebrow{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);padding:14px 18px 8px;display:flex;align-items:center;gap:8px;}
.eyebrow::after{content:'';flex:1;height:1px;background:var(--border);}
.day-hdr{padding:15px 18px 9px;}
.day-title{font-size:21px;font-weight:800;letter-spacing:-.03em;margin-bottom:3px;color:var(--ink);}
.day-sub{font-size:13px;color:var(--ink2);line-height:1.5;}
.warmup-block{margin:0 18px 10px;background:linear-gradient(135deg,rgba(250,204,21,.07),rgba(249,115,22,.05));border:1px solid rgba(250,204,21,.18);border-radius:var(--r);padding:12px 14px;}
.warmup-ttl{font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--star);display:flex;align-items:center;gap:6px;margin-bottom:7px;}
.w-item{font-size:12.5px;color:rgba(250,204,21,.7);padding:4px 0;display:flex;gap:7px;align-items:baseline;border-bottom:1px solid rgba(250,204,21,.08);}
.w-item:last-child{border-bottom:none;}
.w-bullet{color:var(--star);font-size:10px;flex-shrink:0;opacity:.6;}
.ex-list{padding:0 18px;display:flex;flex-direction:column;gap:10px;}
.ex-card{background:var(--nebula);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;transition:all .2s var(--ease);box-shadow:var(--sh);}
.ex-card:hover{box-shadow:var(--sh2);border-color:var(--border2);}
.ex-top{padding:13px 15px 5px;display:flex;align-items:flex-start;gap:10px;}
.ex-info{flex:1;min-width:0;}
.ex-name{font-size:15px;font-weight:700;color:var(--ink);margin-bottom:2px;}
.ex-tl{font-size:12px;font-weight:700;margin-bottom:4px;}
.tag-row{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:3px;}
.mtag{font-size:10px;font-weight:700;letter-spacing:.04em;padding:2px 8px;border-radius:999px;}
.mt-p{background:var(--void-t);color:var(--void);border:1px solid rgba(99,102,241,.25);}
.mt-s{background:rgba(255,255,255,.04);color:var(--ink3);border:1px solid var(--border);}
.badges{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;}
.badge{font-size:9px;font-weight:800;letter-spacing:.07em;text-transform:uppercase;padding:3px 9px;border-radius:999px;}
.b-main{background:var(--star-t);color:var(--star);border:1px solid rgba(250,204,21,.3);}
.b-acc{background:var(--nova-t);color:var(--nova);border:1px solid rgba(249,115,22,.3);}
.b-core{background:var(--pulsar-t);color:var(--pulsar);border:1px solid rgba(168,85,247,.3);}
.b-fore{background:var(--nebula2-t);color:var(--nebula2);border:1px solid rgba(236,72,153,.3);}
.b-pump{background:var(--quasar-t);color:var(--quasar);border:1px solid rgba(6,182,212,.3);}
.ex-acts{padding:3px 15px 10px;display:flex;gap:6px;flex-wrap:wrap;align-items:center;}
.act-btn{background:var(--cosmos);border:1px solid var(--border);border-radius:var(--r3);padding:5px 11px;font-family:var(--font);font-size:12px;font-weight:600;color:var(--ink2);cursor:pointer;display:flex;align-items:center;gap:4px;transition:all .15s;}
.act-btn svg{width:12px;height:12px;stroke-width:2.2;}
.act-btn:hover{border-color:var(--border2);color:var(--ink);}
.act-btn.on{background:var(--void-t);border-color:var(--void);color:var(--void);}
.log-btn{background:var(--cosmos);border:1px solid var(--border);border-radius:var(--r3);padding:5px 11px;font-family:var(--font);font-size:12px;font-weight:600;color:var(--ink2);cursor:pointer;display:flex;align-items:center;gap:4px;transition:all .2s var(--ease);}
.log-btn svg{width:12px;height:12px;stroke-width:2.2;}
.log-btn:hover{border-color:var(--border2);color:var(--ink);}
.log-btn.panel-open{background:var(--void-t);border-color:var(--void);color:var(--void);}
.log-btn.has-data{background:var(--aurora2-t);border-color:var(--aurora2);color:var(--aurora2);font-weight:700;box-shadow:0 0 10px rgba(52,211,153,.2);}
.del-btn{margin-left:auto;background:transparent;border:1px solid var(--border);border-radius:var(--r3);padding:5px 9px;font-family:var(--font);font-size:11px;color:var(--ink3);cursor:pointer;display:flex;align-items:center;gap:3px;transition:all .15s;}
.del-btn:hover{border-color:var(--mars);color:var(--mars);background:var(--mars-t);}
.del-btn svg{width:12px;height:12px;stroke-width:2;}
.det-panel,.log-panel{display:none;animation:slideDown .2s var(--ease);}
.det-panel.on,.log-panel.on{display:block;}
@keyframes slideDown{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.how-box{margin:0 15px 12px;background:linear-gradient(135deg,var(--cosmos),var(--stardust));border:1px solid var(--border);border-radius:var(--r2);padding:11px 13px;font-size:13px;color:var(--ink2);line-height:1.7;}
.how-p{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--void);margin-bottom:5px;}
.log-inner{padding:0 15px 12px;}
.log-hdr{display:grid;grid-template-columns:26px 1fr 1fr 58px 68px;gap:4px;margin-bottom:5px;}
.lhc{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);}
.log-row{display:grid;grid-template-columns:26px 1fr 1fr 58px 68px;gap:4px;margin-bottom:5px;align-items:center;}
.set-n{font-family:var(--mono);font-size:11px;font-weight:600;color:var(--ink3);text-align:center;}
.li{background:var(--cosmos);border:1px solid var(--border);border-radius:var(--r3);padding:7px 8px;font-family:var(--mono);font-size:13px;font-weight:600;color:var(--ink);width:100%;transition:all .15s;-moz-appearance:textfield;}
.li::-webkit-outer-spin-button,.li::-webkit-inner-spin-button{-webkit-appearance:none;}
.li::placeholder{color:var(--ink3);font-weight:400;font-family:var(--font);}
.li:focus{outline:none;border-color:var(--void);background:var(--stardust);}
.li.fl{border-color:var(--aurora2)!important;background:var(--aurora2-t)!important;}
.rsel{background:var(--cosmos);border:1px solid var(--border);border-radius:var(--r3);padding:7px 3px;font-family:var(--font);font-size:12px;color:var(--ink);width:100%;appearance:none;-webkit-appearance:none;text-align:center;cursor:pointer;}
.rsel:focus{outline:none;border-color:var(--void);}
.rsel option{background:var(--nebula);}
.note-i{background:var(--cosmos);border:1px solid var(--border);border-radius:var(--r3);padding:7px 8px;font-family:var(--font);font-size:12px;color:var(--ink);width:100%;}
.note-i::placeholder{color:var(--ink3);}
.note-i:focus{outline:none;border-color:var(--void);}
.add-set-row{padding:4px 0 0;}
.add-set-btn{background:transparent;border:1.5px dashed var(--border);border-radius:var(--r3);padding:6px 14px;font-family:var(--font);font-size:12px;font-weight:600;color:var(--ink3);cursor:pointer;display:flex;align-items:center;gap:5px;transition:all .15s;}
.add-set-btn:hover{border-color:var(--aurora2);color:var(--aurora2);background:var(--aurora2-t);}
.add-set-btn svg{width:12px;height:12px;stroke-width:2.5;}
.save-row{padding:13px 18px 0;display:flex;gap:9px;}
.btn-pri{flex:1;border:none;border-radius:var(--r2);padding:14px;font-family:var(--font);font-size:14px;font-weight:700;color:#fff;cursor:pointer;transition:all .15s;background:linear-gradient(135deg,var(--void),var(--pulsar));box-shadow:0 4px 16px rgba(99,102,241,.4);}
.btn-pri:hover{opacity:.9;}.btn-pri:active{transform:scale(.98);}
.btn-sec{background:var(--nebula);border:1px solid var(--border);border-radius:var(--r2);padding:14px 16px;font-family:var(--font);font-size:14px;font-weight:600;color:var(--ink2);cursor:pointer;transition:all .15s;}
.btn-sec:hover{border-color:var(--border2);color:var(--ink);}
.add-ex-row{padding:11px 18px 0;}
.add-ex-btn{width:100%;background:var(--nebula);border:1.5px dashed var(--border);border-radius:var(--r);padding:13px;font-family:var(--font);font-size:13px;font-weight:600;color:var(--ink3);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .18s;}
.add-ex-btn:hover{border-color:var(--star);color:var(--star);background:var(--star-t);}
.add-ex-btn svg{width:15px;height:15px;stroke-width:2.2;}
.sec-intro{margin:13px 18px 10px;border-radius:var(--r);padding:13px 15px;}
.sec-ttl{font-size:14px;font-weight:800;margin-bottom:3px;}
.sec-sub{font-size:12px;color:var(--ink2);line-height:1.5;}
.filter-row{display:flex;gap:7px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding:0 18px 6px;}
.filter-row::-webkit-scrollbar{display:none;}
.fchip{background:var(--nebula);border:1px solid var(--border);border-radius:999px;padding:7px 16px;font-family:var(--font);font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap;transition:all .18s;color:var(--ink2);box-shadow:var(--sh);}
.fchip:hover{border-color:var(--border2);color:var(--ink);}
.fchip.on{color:#fff;}
.muscle-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;padding:0 18px;margin-bottom:12px;}
.mgrp-btn{background:var(--nebula);border:1.5px solid var(--border);border-radius:var(--r2);padding:11px 13px;font-family:var(--font);font-size:12px;font-weight:700;color:var(--ink);cursor:pointer;display:flex;align-items:center;gap:8px;transition:all .18s;box-shadow:var(--sh);}
.mgrp-btn:hover{box-shadow:var(--sh2);transform:translateY(-1px);}
.mgrp-btn.on{box-shadow:var(--sh2);}
.mico{font-size:18px;}.mlbl{line-height:1.3;}.msub{font-size:10px;color:var(--ink3);font-weight:500;}
.lib-results{padding:0 18px;display:flex;flex-direction:column;gap:8px;}
.lib-empty{text-align:center;padding:28px 20px;color:var(--ink3);font-size:14px;}
.ro-list{padding:8px 18px 0;display:flex;flex-direction:column;gap:8px;}
.bnav{position:fixed;bottom:0;left:0;right:0;z-index:60;background:rgba(10,14,26,.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid var(--border);display:flex;padding:7px 0 max(8px,env(safe-area-inset-bottom));box-shadow:0 -4px 20px rgba(0,0,0,.5);}
.nbtn{flex:1;background:transparent;border:none;font-family:var(--font);font-size:9px;font-weight:700;color:var(--ink3);cursor:pointer;padding:4px 0;display:flex;flex-direction:column;align-items:center;gap:3px;transition:all .15s;letter-spacing:.04em;text-transform:uppercase;}
.nbtn svg{width:20px;height:20px;stroke-width:1.8;transition:all .15s;}
.nbtn:hover{color:var(--ink2);}
.nbtn.on-workout{color:var(--star);}
.nbtn.on-workout svg{filter:drop-shadow(0 0 5px rgba(250,204,21,.5));}
.nbtn.on-pump{color:var(--quasar);}
.nbtn.on-pump svg{filter:drop-shadow(0 0 5px rgba(6,182,212,.5));}
.nbtn.on-core{color:var(--pulsar);}
.nbtn.on-core svg{filter:drop-shadow(0 0 5px rgba(168,85,247,.5));}
.nbtn.on-lib{color:var(--void);}
.nbtn.on-lib svg{filter:drop-shadow(0 0 5px rgba(99,102,241,.5));}
.nbtn.on-history{color:var(--aurora2);}
.nbtn.on-history svg{filter:drop-shadow(0 0 5px rgba(52,211,153,.5));}
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(14px);background:var(--aurora2);color:#031208;font-size:13px;font-weight:700;padding:10px 22px;border-radius:999px;opacity:0;pointer-events:none;transition:all .25s var(--ease);white-space:nowrap;z-index:999;box-shadow:0 4px 20px rgba(52,211,153,.5);}
.toast.on{opacity:1;transform:translateX(-50%) translateY(0);}
.overlay{display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,.72);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);align-items:flex-end;justify-content:center;}
.overlay.on{display:flex;}
.modal{background:var(--nebula);border-top:1px solid var(--border);border-radius:24px 24px 0 0;width:100%;max-width:540px;padding:17px 18px max(18px,env(safe-area-inset-bottom));max-height:90vh;overflow-y:auto;box-shadow:var(--sh2);}
.m-handle{width:36px;height:4px;background:var(--border2);border-radius:2px;margin:0 auto 14px;}
.m-title{font-size:18px;font-weight:800;color:var(--ink);margin-bottom:13px;letter-spacing:-.02em;}
.m-field{margin-bottom:10px;}
.m-lbl{display:block;font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--ink3);margin-bottom:5px;}
.m-inp,.m-sel,.m-ta{width:100%;background:var(--cosmos);border:1px solid var(--border);border-radius:var(--r2);padding:11px 13px;font-family:var(--font);font-size:14px;color:var(--ink);outline:none;transition:border-color .15s;}
.m-inp::placeholder,.m-ta::placeholder{color:var(--ink3);}
.m-inp:focus,.m-sel:focus,.m-ta:focus{border-color:var(--void);background:var(--stardust);}
.m-ta{resize:none;height:70px;}
.m-sel option{background:var(--nebula);}
.m-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.m-acts{display:flex;gap:9px;margin-top:14px;}
.hist-wrap{padding:13px 18px;display:flex;flex-direction:column;gap:12px;}
.chart-card{background:var(--nebula);border:1px solid var(--border);border-radius:var(--r);padding:16px;box-shadow:var(--sh);}
.chart-title{font-size:13px;font-weight:700;color:var(--aurora2);margin-bottom:3px;display:flex;align-items:center;gap:6px;}
.chart-sub{font-size:11px;color:var(--ink3);margin-bottom:12px;}
#weight-canvas{width:100%;height:160px;display:block;}
.chart-empty{text-align:center;padding:30px;color:var(--ink3);font-size:13px;}
.chart-legend{display:flex;gap:12px;margin-top:10px;flex-wrap:wrap;}
.chart-legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--ink3);}
.chart-legend-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.hcard{background:var(--nebula);border:1px solid var(--border);border-radius:var(--r);padding:14px 15px;box-shadow:var(--sh);}
.h-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:7px;}
.h-date{font-size:11px;font-weight:600;color:var(--ink3);}
.h-day{font-size:13px;font-weight:700;color:var(--ink);}
.h-ci{display:flex;gap:10px;margin-bottom:7px;padding-bottom:7px;border-bottom:1px solid var(--border);flex-wrap:wrap;}
.h-stat{font-size:12px;color:var(--ink2);}
.h-stat b{color:var(--star);font-weight:700;}
.h-ex{display:flex;justify-content:space-between;align-items:baseline;padding:5px 0;border-bottom:1px solid var(--border);font-size:13px;}
.h-ex:last-child{border-bottom:none;}
.h-ex-name{color:var(--ink);font-weight:600;}
.h-best{font-family:var(--mono);font-size:12px;color:var(--quasar);font-weight:600;}
.empty{text-align:center;padding:50px 20px;color:var(--ink3);}
.empty .ico{font-size:36px;display:block;margin-bottom:10px;}
@media(max-width:390px){.log-hdr,.log-row{grid-template-columns:22px 1fr 1fr 50px 58px;}.muscle-grid{grid-template-columns:repeat(auto-fill,minmax(120px,1fr));}}


/* ── ROCKET ANIMATIONS ── */
@keyframes flame-flicker{
  0%,100%{transform:scaleY(1) scaleX(1);opacity:1;}
  25%{transform:scaleY(1.18) scaleX(.92);opacity:.9;}
  50%{transform:scaleY(.88) scaleX(1.08);opacity:1;}
  75%{transform:scaleY(1.12) scaleX(.95);opacity:.85;}
}
@keyframes flame-glow{
  0%,100%{filter:drop-shadow(0 2px 4px rgba(249,115,22,.7));}
  50%{filter:drop-shadow(0 3px 8px rgba(250,204,21,.9));}
}
@keyframes rocket-float{
  0%,100%{transform:translateY(0) rotate(-45deg);}
  50%{transform:translateY(-3px) rotate(-45deg);}
}
@keyframes rocket-float-up{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-4px);}
}
@keyframes rocket-shake{
  0%,100%{transform:rotate(-45deg) translateX(0);}
  25%{transform:rotate(-46deg) translateX(.5px);}
  75%{transform:rotate(-44deg) translateX(-.5px);}
}
.rocket-svg{display:inline-block;vertical-align:middle;}
.rocket-svg .flame-main{transform-origin:50% 0%;animation:flame-flicker .35s ease-in-out infinite;}
.rocket-svg .flame-left{transform-origin:50% 0%;animation:flame-flicker .35s ease-in-out infinite .08s;}
.rocket-svg .flame-right{transform-origin:50% 0%;animation:flame-flicker .35s ease-in-out infinite .16s;}
.rocket-svg .rocket-body{animation:rocket-shake 1.2s ease-in-out infinite;}
/* Logo rocket — float gently, rotated 45deg pointing up-right */
.logo-rocket{animation:rocket-float 2.2s ease-in-out infinite;filter:drop-shadow(0 0 6px rgba(250,204,21,.5));}
/* Save button rocket — faster shake when hovering the button */
.btn-pri:hover .save-rocket{animation:rocket-shake .15s ease-in-out infinite!important;}
.save-rocket{animation:rocket-float-up 1.8s ease-in-out infinite;}
/* Empty chart rocket — slow float */
.empty-rocket{animation:rocket-float-up 2.5s ease-in-out infinite;filter:drop-shadow(0 0 8px rgba(249,115,22,.4));}

/* ═══════════════════════════════════════════════════════
   DESIGN POLISH LAYER — animations, depth, micro-interactions
   All CSS-only. No JS dependencies.
   ═══════════════════════════════════════════════════════ */

/* ── ANIMATED STARFIELD BACKGROUND ── */
body::before{
  content:'';
  position:fixed;inset:0;z-index:-2;
  background:
    radial-gradient(2px 2px at 20% 30%, rgba(255,255,255,.5), transparent),
    radial-gradient(2px 2px at 60% 70%, rgba(255,255,255,.35), transparent),
    radial-gradient(1px 1px at 50% 50%, rgba(255,255,255,.4), transparent),
    radial-gradient(1px 1px at 80% 10%, rgba(255,255,255,.3), transparent),
    radial-gradient(2px 2px at 90% 60%, rgba(255,255,255,.35), transparent),
    radial-gradient(1px 1px at 33% 80%, rgba(255,255,255,.3), transparent),
    radial-gradient(1.5px 1.5px at 15% 65%, rgba(168,85,247,.4), transparent),
    radial-gradient(1.5px 1.5px at 75% 40%, rgba(6,182,212,.4), transparent);
  background-size:200% 200%;
  animation:stars-drift 60s linear infinite;
  opacity:.5;pointer-events:none;
}
@keyframes stars-drift{
  0%{background-position:0% 0%;}
  100%{background-position:200% 200%;}
}
/* Subtle aurora glow that breathes */
body::after{
  content:'';
  position:fixed;top:-20%;left:-10%;width:120%;height:60%;z-index:-2;
  background:radial-gradient(ellipse at 50% 0%, rgba(99,102,241,.12), transparent 60%);
  animation:aurora-pulse 8s ease-in-out infinite;
  pointer-events:none;
}
@keyframes aurora-pulse{
  0%,100%{opacity:.5;transform:translateY(0) scale(1);}
  50%{opacity:.9;transform:translateY(10px) scale(1.05);}
}

/* ── HEADER: glassy shimmer on the logo text ── */
.logo-text{
  background:linear-gradient(135deg,var(--star),var(--nova),var(--star)) !important;
  background-size:200% auto !important;
  -webkit-background-clip:text !important;background-clip:text !important;
  animation:logo-shimmer 4s linear infinite;
}
@keyframes logo-shimmer{
  0%{background-position:0% center;}
  100%{background-position:200% center;}
}

/* ── CLOCK: subtle digital pulse ── */
.clock{animation:clock-pulse 2s ease-in-out infinite;}
@keyframes clock-pulse{
  0%,100%{text-shadow:0 0 10px rgba(99,102,241,.4);}
  50%{text-shadow:0 0 16px rgba(99,102,241,.7),0 0 24px rgba(99,102,241,.3);}
}

/* ── STREAK DOTS: pop-in + glow pulse on completed ── */
.sdot.done{
  animation:dot-pop .4s var(--ease) both, dot-glow 2.5s ease-in-out infinite;
}
@keyframes dot-pop{
  0%{transform:scale(0);}
  60%{transform:scale(1.25);}
  100%{transform:scale(1);}
}
@keyframes dot-glow{
  0%,100%{box-shadow:0 0 6px rgba(52,211,153,.35);}
  50%{box-shadow:0 0 12px rgba(52,211,153,.7),0 0 4px rgba(52,211,153,.5);}
}
.sdot.today-e{animation:today-blink 1.5s ease-in-out infinite;}
@keyframes today-blink{
  0%,100%{border-color:var(--void);opacity:.7;}
  50%{border-color:var(--comet);opacity:1;}
}

/* ── CARDS: lift + glow on hover, entrance animation ── */
.ex-card{position:relative;overflow:hidden;}
.ex-card::before{
  content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.04),transparent);
  transition:left .6s var(--ease);pointer-events:none;z-index:1;
}
.ex-card:hover::before{left:100%;}
.ex-card:hover{transform:translateY(-2px);}

/* Card entrance stagger */
.ex-list .ex-card{animation:card-rise .4s var(--ease) both;}
.ex-list .ex-card:nth-child(1){animation-delay:.02s;}
.ex-list .ex-card:nth-child(2){animation-delay:.06s;}
.ex-list .ex-card:nth-child(3){animation-delay:.10s;}
.ex-list .ex-card:nth-child(4){animation-delay:.14s;}
.ex-list .ex-card:nth-child(5){animation-delay:.18s;}
.ex-list .ex-card:nth-child(6){animation-delay:.22s;}
.ex-list .ex-card:nth-child(7){animation-delay:.26s;}
.ex-list .ex-card:nth-child(8){animation-delay:.30s;}
.ex-list .ex-card:nth-child(n+9){animation-delay:.34s;}
@keyframes card-rise{
  from{opacity:0;transform:translateY(14px);}
  to{opacity:1;transform:translateY(0);}
}
.ro-list .ex-card{animation:card-rise .35s var(--ease) both;}

/* ── BUTTONS: press ripple + shine ── */
.btn-pri{position:relative;overflow:hidden;}
.btn-pri::after{
  content:'';position:absolute;top:50%;left:50%;width:0;height:0;
  background:radial-gradient(circle,rgba(255,255,255,.3),transparent);
  border-radius:50%;transform:translate(-50%,-50%);
  transition:width .5s,height .5s;pointer-events:none;
}
.btn-pri:active::after{width:300px;height:300px;}
.btn-pri{background-size:200% auto !important;animation:btn-flow 3s linear infinite;}
@keyframes btn-flow{
  0%{background-position:0% center;}
  100%{background-position:200% center;}
}

/* ── DAY TABS: active glow sweep ── */
.dtab.on{animation:tab-glow 2.5s ease-in-out infinite;}
@keyframes tab-glow{
  0%,100%{box-shadow:0 4px 16px rgba(250,204,21,.2);}
  50%{box-shadow:0 4px 24px rgba(250,204,21,.4),0 0 12px rgba(249,115,22,.2);}
}

/* ── NAV: active icon bounce + glow ── */
.nbtn svg{transition:transform .25s var(--ease);}
.nbtn.on-workout svg,.nbtn.on-pump svg,.nbtn.on-core svg,
.nbtn.on-lib svg,.nbtn.on-history svg{
  animation:nav-bounce .4s var(--ease);
}
@keyframes nav-bounce{
  0%{transform:translateY(0) scale(1);}
  50%{transform:translateY(-4px) scale(1.15);}
  100%{transform:translateY(0) scale(1);}
}

/* ── INPUTS: focus glow ring ── */
.li:focus,.note-i:focus,.rsel:focus,.ci-inp:focus,.m-inp:focus,.m-sel:focus,.m-ta:focus{
  box-shadow:0 0 0 3px rgba(99,102,241,.15),0 0 12px rgba(99,102,241,.2);
}
/* Filled input celebration */
.li.fl{animation:fill-flash .4s var(--ease);}
@keyframes fill-flash{
  0%{box-shadow:0 0 0 0 rgba(52,211,153,.5);}
  100%{box-shadow:0 0 0 6px rgba(52,211,153,0);}
}

/* ── MOOD BUTTONS: bounce on select ── */
.mbtn{transition:all .2s var(--ease);}
.mbtn:active{transform:scale(.85);}
.mbtn.on{animation:mood-pop .4s var(--ease);}
@keyframes mood-pop{
  0%{transform:scale(1);}
  50%{transform:scale(1.3) rotate(8deg);}
  100%{transform:scale(1);}
}

/* ── LOG BUTTON success state pulse ── */
.log-btn.has-data{animation:success-pulse 2s ease-in-out infinite;}
@keyframes success-pulse{
  0%,100%{box-shadow:0 0 10px rgba(52,211,153,.2);}
  50%{box-shadow:0 0 18px rgba(52,211,153,.5);}
}

/* ── SECTION INTRO: gradient border flow ── */
.sec-intro{position:relative;overflow:hidden;}
.sec-intro::before{
  content:'';position:absolute;inset:0;border-radius:var(--r);padding:1px;
  background:linear-gradient(120deg,transparent,rgba(255,255,255,.1),transparent);
  background-size:200% auto;animation:border-flow 3s linear infinite;
  -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
  -webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none;
}
@keyframes border-flow{
  0%{background-position:0% center;}
  100%{background-position:200% center;}
}

/* ── FILTER CHIPS: active scale + glow ── */
.fchip{transition:all .2s var(--ease);}
.fchip:active{transform:scale(.93);}
.fchip.on{animation:chip-pop .3s var(--ease);}
@keyframes chip-pop{
  0%{transform:scale(1);}
  50%{transform:scale(1.08);}
  100%{transform:scale(1);}
}

/* ── MUSCLE GRID: hover lift + icon wiggle ── */
.mgrp-btn{transition:all .25s var(--ease);}
.mgrp-btn:hover .mico{animation:icon-wiggle .5s var(--ease);}
@keyframes icon-wiggle{
  0%,100%{transform:rotate(0);}
  25%{transform:rotate(-10deg) scale(1.15);}
  75%{transform:rotate(10deg) scale(1.15);}
}
.mgrp-btn.on .mico{animation:icon-bounce 1.5s ease-in-out infinite;}
@keyframes icon-bounce{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-3px);}
}

/* ── CHECK-IN BLOCKS: subtle hover glow ── */
.ci-block{transition:all .25s var(--ease);}
.ci-block:focus-within{
  border-color:var(--void);
  box-shadow:0 0 16px rgba(99,102,241,.2);
}

/* ── WARMUP ITEMS: stagger fade-in ── */
.warmup-block .w-item{animation:warmup-slide .3s var(--ease) both;}
.warmup-block .w-item:nth-child(2){animation-delay:.05s;}
.warmup-block .w-item:nth-child(3){animation-delay:.10s;}
.warmup-block .w-item:nth-child(4){animation-delay:.15s;}
.warmup-block .w-item:nth-child(5){animation-delay:.20s;}
.warmup-block .w-item:nth-child(6){animation-delay:.25s;}
@keyframes warmup-slide{
  from{opacity:0;transform:translateX(-8px);}
  to{opacity:1;transform:translateX(0);}
}

/* ── DAY TITLE: gradient text shimmer ── */
.day-title{
  background:linear-gradient(135deg,var(--ink),var(--void),var(--ink)) !important;
  background-size:200% auto !important;
  -webkit-background-clip:text !important;background-clip:text !important;
  -webkit-text-fill-color:transparent !important;
  animation:title-shimmer 5s linear infinite;
}
@keyframes title-shimmer{
  0%{background-position:0% center;}
  100%{background-position:200% center;}
}

/* ── TOAST: bounce entrance ── */
.toast.on{animation:toast-bounce .5s var(--ease);}
@keyframes toast-bounce{
  0%{transform:translateX(-50%) translateY(40px) scale(.8);opacity:0;}
  60%{transform:translateX(-50%) translateY(-6px) scale(1.05);}
  100%{transform:translateX(-50%) translateY(0) scale(1);opacity:1;}
}

/* ── MODAL: slide up with backdrop fade ── */
.overlay.on{animation:overlay-fade .25s var(--ease);}
@keyframes overlay-fade{from{opacity:0;}to{opacity:1;}}
.overlay.on .modal{animation:modal-slide .35s var(--ease);}
@keyframes modal-slide{
  from{transform:translateY(100%);}
  to{transform:translateY(0);}
}

/* ── SECTION TRANSITIONS ── */
.sec.on{animation:sec-fade .35s var(--ease);}
@keyframes sec-fade{
  from{opacity:0;transform:translateY(8px);}
  to{opacity:1;transform:translateY(0);}
}

/* ── HISTORY CARDS: rise stagger ── */
.hist-wrap .hcard,.hist-wrap .chart-card{animation:card-rise .4s var(--ease) both;}
.hist-wrap .chart-card{animation-delay:.02s;}
.hist-wrap .hcard:nth-child(2){animation-delay:.08s;}
.hist-wrap .hcard:nth-child(3){animation-delay:.14s;}
.hist-wrap .hcard:nth-child(4){animation-delay:.20s;}
.hist-wrap .hcard:nth-child(n+5){animation-delay:.26s;}

/* ── ADD buttons: dashed border pulse ── */
.add-ex-btn:hover,.add-set-btn:hover{animation:dash-pulse 1s ease-in-out infinite;}
@keyframes dash-pulse{
  0%,100%{border-color:var(--star);}
  50%{border-color:var(--nova);}
}

/* ── Reduce motion accessibility ── */
@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{
    animation-duration:.01ms !important;
    animation-iteration-count:1 !important;
    transition-duration:.01ms !important;
  }
  body::before,body::after{animation:none !important;}
}


/* ── THEME TOGGLE BUTTON ── */
#theme-toggle{
  background:var(--cosmos);border:1px solid var(--border);
  border-radius:999px;width:34px;height:34px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:16px;transition:all .25s var(--ease);
  flex-shrink:0;padding:0;line-height:1;
}
#theme-toggle:hover{border-color:var(--border2);transform:scale(1.08);box-shadow:var(--sh);}
#theme-toggle:active{transform:scale(.92);}
#theme-icon{display:inline-block;transition:transform .4s var(--ease);}
#theme-toggle:hover #theme-icon{transform:rotate(20deg);}


/* ═══════════════════════════════════════════════════════════════
   V0 LIQUID GLASS DESIGN LAYER
   Aurora mesh + glass surfaces + premium typography + spring motion
   ═══════════════════════════════════════════════════════════════ */

/* Import Space Grotesk for display type */
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&display=swap');

/* ── AURORA MESH BACKGROUND (replaces basic radial gradients) ── */
body{
  background:
    radial-gradient(ellipse 80% 50% at 15% 20%, rgba(187,147,255,.20), transparent 60%),
    radial-gradient(ellipse 70% 60% at 85% 30%, rgba(51,219,242,.18), transparent 55%),
    radial-gradient(ellipse 90% 70% at 50% 90%, rgba(255,121,196,.15), transparent 50%),
    radial-gradient(ellipse 60% 50% at 20% 80%, rgba(61,240,168,.12), transparent 50%),
    var(--space) !important;
  background-attachment:fixed !important;
  background-size:200% 200% !important;
  animation:mesh-drift 22s ease-in-out infinite;
}
[data-theme="light"] body{
  background:
    radial-gradient(ellipse 80% 50% at 15% 20%, rgba(124,58,237,.10), transparent 60%),
    radial-gradient(ellipse 70% 60% at 85% 30%, rgba(8,145,178,.08), transparent 55%),
    radial-gradient(ellipse 90% 70% at 50% 90%, rgba(225,29,116,.06), transparent 50%),
    radial-gradient(ellipse 60% 50% at 20% 80%, rgba(5,150,105,.06), transparent 50%),
    var(--space) !important;
  background-attachment:fixed !important;
  background-size:200% 200% !important;
  animation:mesh-drift 22s ease-in-out infinite;
}
@keyframes mesh-drift{
  0%,100%{background-position:0% 0%;}
  50%{background-position:100% 100%;}
}

/* Multicolor starfield with twinkle */
body::before{
  background:
    radial-gradient(1.5px 1.5px at 12% 22%, rgba(255,211,56,.7), transparent),
    radial-gradient(1.5px 1.5px at 28% 68%, rgba(51,219,242,.6), transparent),
    radial-gradient(2px 2px at 45% 35%, rgba(187,147,255,.5), transparent),
    radial-gradient(1px 1px at 62% 12%, rgba(255,121,196,.6), transparent),
    radial-gradient(1.5px 1.5px at 78% 56%, rgba(61,240,214,.5), transparent),
    radial-gradient(1px 1px at 88% 82%, rgba(255,146,72,.6), transparent),
    radial-gradient(1.5px 1.5px at 95% 25%, rgba(255,255,255,.5), transparent),
    radial-gradient(1px 1px at 35% 88%, rgba(255,255,255,.4), transparent) !important;
  background-size:300% 300% !important;
  animation:stars-drift 60s linear infinite, twinkle 5s ease-in-out infinite !important;
  opacity:.7 !important;
}
@keyframes twinkle{
  0%,100%{opacity:.7;}
  50%{opacity:.3;}
}
[data-theme="light"] body::before{opacity:.15 !important;}

/* ── LIQUID GLASS UTILITY — applied to cards, header, nav, modal ── */
.hdr{
  background:var(--spec),var(--glass-strong) !important;
  backdrop-filter:var(--glass-blur) !important;
