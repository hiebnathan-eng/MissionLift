  h+='<div class="log-panel'+(isLogOn?" on":"")+'" id="log_'+k+'">';
  h+='<div class="log-inner"><div class="log-hdr"><span class="lhc">#</span><span class="lhc">Weight</span><span class="lhc">Reps</span><span class="lhc">RPE</span><span class="lhc">Note</span></div>';
