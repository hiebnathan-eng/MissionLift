/* ── READ-ONLY CARD ── */
function buildROCard(ex,color,tc,prefix){
  var uid=prefix+"_"+(ex.name||"").replace(/[^a-zA-Z0-9]/g,"_").slice(0,40);
  var on=!!roDetPanels[uid];
  var h='<div class="ex-card">';
  h+='<div class="ex-top"><div class="ex-info">';
  h+='<div class="ex-name">'+escHtml(ex.name)+'</div>';
  if(ex.target)h+='<div class="ex-tl" style="color:'+color+'">'+escHtml(ex.target)+'</div>';
  h+='<div class="tag-row"><span class="mtag" style="background:'+tc+';color:'+color+';border:1px solid '+color+'44">\uD83C\uDFAF '+escHtml(ex.primary)+'</span>';
  if(ex.secondary&&ex.secondary!=="—")h+='<span class="mtag mt-s">'+escHtml(ex.secondary)+'</span>';
  h+='</div></div></div>';
  h+='<div class="ex-acts"><button class="act-btn'+(on?' on':'')+'" id="robtn_'+uid+'" onclick="toggleRODet(this.dataset.uid,this)" data-uid="'+uid+'"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>How to</button></div>';
  h+='<div class="det-panel'+(on?" on":"")+'" id="rodet_'+uid+'"><div class="how-box"><div class="how-p" style="color:'+color+'">\uD83C\uDFAF Primary: '+escHtml(ex.primary)+'</div>'+escHtml(ex.how||"")+'</div></div>';
  h+='</div>';
  return h;
}
function toggleRODet(uid,btn){
  roDetPanels[uid]=!roDetPanels[uid];
  var p=document.getElementById("rodet_"+uid);if(p)p.classList.toggle("on",roDetPanels[uid]);
  if(btn)btn.classList.toggle("on",roDetPanels[uid]);
}

/* ── HISTORY + WEIGHT CHART ── */
function renderHistory(){
  var logs=getLogs();
  var wrap=document.getElementById("hist-wrap");if(!wrap)return;
  if(!logs.length){wrap.innerHTML='<div class="empty"><span class="ico">\uD83C\uDF0C</span>No missions logged yet.<br>Complete your first workout to start tracking.</div>';return;}

  /* collect weight data — ascending order for chart */
  /* collect weight data from dedicated daily weight log + workout log fallback */
  var wlog=getWLog();
  var weightMap={};
  /* backward compat: load from workout logs first */
  for(var i=logs.length-1;i>=0;i--){
    var l=logs[i];
    if(l.weight&&parseFloat(l.weight)>0){
      var dk=new Date(l.ts||0).toDateString();
      if(!weightMap[dk])weightMap[dk]={date:l.date,w:parseFloat(l.weight),ts:l.ts||0};
    }
  }
  /* daily weight log takes priority (dedicated entries) */
  Object.keys(wlog).forEach(function(dateStr){
    var d=new Date(dateStr);
    if(!isNaN(d.getTime())){
      weightMap[dateStr]={
        date:d.toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"}),
        w:wlog[dateStr],ts:d.getTime()
      };
    }
  });
  var weightData=Object.values(weightMap).sort(function(a,b){return a.ts-b.ts;});
  if(weightData.length>60)weightData=weightData.slice(weightData.length-60);

  var html='<div class="chart-card"><div class="chart-title">\uD83D\uDCC8 Body weight trend</div>';
  if(weightData.length<2){
    html+='<div class="chart-sub">Log weight in check-in across multiple sessions to see your trend.</div>';
    html+='<div class="chart-empty">🚀 Log weight daily — chart appears after 2 entries</div>';
  } else {
    var latest=weightData[weightData.length-1].w;
    var first=weightData[0].w;
    var diff=(latest-first);
    html+='<div class="chart-sub">Last '+weightData.length+' entries · Change: '+(diff>=0?"+":"")+diff.toFixed(1)+" lbs</div>";
    html+='<canvas id="weight-canvas" width="600" height="160"></canvas>';
    html+='<div class="chart-legend">';
    html+='<div class="chart-legend-item"><div class="chart-legend-dot" style="background:var(--aurora2)"></div>Current: <strong>'+latest.toFixed(1)+' lbs</strong></div>';
    html+='<div class="chart-legend-item"><div class="chart-legend-dot" style="background:'+(diff<=0?"var(--aurora2)":"var(--mars)")+'"></div>Change: <strong>'+(diff>=0?"+":"")+diff.toFixed(1)+' lbs</strong></div>';
    html+='<div class="chart-legend-item"><div class="chart-legend-dot" style="background:var(--void)"></div>'+weightData.length+' entries</div>';
    html+='</div>';
  }
  html+='</div>';

  /* session cards */
  logs.forEach(function(entry){
    var rows=(entry.exercises||[]).map(function(ex){
      var sets=Object.values(ex.sets||{});
      var logged=sets.filter(function(s){return s.w||s.r;});
      if(!logged.length)return "";
      var best=logged.reduce(function(a,b){return parseFloat(b.w||0)>parseFloat(a.w||0)?b:a;},logged[0]);
      var bs=[best.w?best.w+" lbs":"",best.r?best.r+" reps":""].filter(Boolean).join(" \xD7 ");
      return '<div class="h-ex"><span class="h-ex-name">'+escHtml(ex.name)+'</span><span class="h-best">'+escHtml(bs)+'</span></div>';
    }).filter(function(r){return!!r;}).join("");
    if(!rows)return;
    html+='<div class="hcard">';
    html+='<div class="h-top"><span class="h-date">'+escHtml(entry.date||"")+'</span><span class="h-day">'+escHtml((entry.dayName||"").split("\u2014")[0].trim()||entry.dayId)+'</span></div>';
    if(entry.weight||entry.mood){
      html+='<div class="h-ci">';
      if(entry.weight)html+='<span class="h-stat">\uD83C\uDF0C Weight <b>'+escHtml(entry.weight)+' lbs</b></span>';
      if(entry.mood)html+='<span class="h-stat">Mood <b>'+escHtml(entry.mood)+'</b></span>';
      html+='</div>';
    }
    html+=rows+'</div>';
  });

  wrap.innerHTML=html;
  if(weightData.length>=2)setTimeout(function(){drawWeightChart(weightData);},60);
}

function drawWeightChart(data){
  var canvas=document.getElementById("weight-canvas");if(!canvas)return;
  var ctx=canvas.getContext("2d");if(!ctx)return;
  var isLight=document.documentElement.getAttribute("data-theme")==="light";
  var gridColor=isLight?"rgba(15,22,40,0.08)":"rgba(255,255,255,0.06)";
  var labelColor=isLight?"rgba(91,101,133,0.85)":"rgba(136,146,192,0.75)";
  var pointCenter=isLight?"#ffffff":"#0a0e1a";
  var lineColor=isLight?"rgba(5,150,105,0.95)":"rgba(52,211,153,0.92)";
  var lineStroke=isLight?"rgba(5,150,105,1)":"rgba(52,211,153,1)";
  var areaTop=isLight?"rgba(5,150,105,0.20)":"rgba(52,211,153,0.28)";
  var areaBot=isLight?"rgba(5,150,105,0.01)":"rgba(52,211,153,0.01)";
  var dotFill=isLight?"#059669":"#34d399";
  var dotGlow=isLight?"rgba(5,150,105,0.25)":"rgba(52,211,153,0.25)";
  var rect=canvas.getBoundingClientRect();
  var dpr=window.devicePixelRatio||1;
  canvas.width=Math.floor(rect.width*dpr);
  canvas.height=160*dpr;
  ctx.scale(dpr,dpr);
  var W=rect.width,H=160;
  var pad={top:18,right:16,bottom:28,left:46};
  var cW=W-pad.left-pad.right,cH=H-pad.top-pad.bottom;
  var weights=data.map(function(d){return d.w;});
  var minW=Math.min.apply(null,weights),maxW=Math.max.apply(null,weights);
  var range=maxW-minW||1;
  var buf=range*0.18+1;
  var yMin=minW-buf,yMax=maxW+buf,yRange=yMax-yMin;
  function xP(i){return pad.left+(i/(data.length-1))*cW;}
  function yP(w){return pad.top+(1-(w-yMin)/yRange)*cH;}

  /* grid */
  ctx.strokeStyle=gridColor;ctx.lineWidth=1;
  for(var g=0;g<=4;g++){
    var gy=pad.top+(g/4)*cH;
    ctx.beginPath();ctx.moveTo(pad.left,gy);ctx.lineTo(W-pad.right,gy);ctx.stroke();
    var lv=(yMax-(g/4)*yRange).toFixed(0);
    ctx.fillStyle=labelColor;ctx.font="10px Inter,system-ui,sans-serif";ctx.textAlign="right";
    ctx.fillText(lv,pad.left-5,gy+4);
  }

  /* area fill */
  ctx.beginPath();ctx.moveTo(xP(0),yP(data[0].w));
  data.forEach(function(d,i){if(i>0)ctx.lineTo(xP(i),yP(d.w));});
  ctx.lineTo(xP(data.length-1),pad.top+cH);ctx.lineTo(pad.left,pad.top+cH);ctx.closePath();
  var ag=ctx.createLinearGradient(0,pad.top,0,pad.top+cH);
  ag.addColorStop(0,areaTop);ag.addColorStop(1,areaBot);
  ctx.fillStyle=ag;ctx.fill();

  /* line (smooth quadratic bezier) */
  ctx.beginPath();ctx.moveTo(xP(0),yP(data[0].w));
  for(var i=1;i<data.length-1;i++){
    var mx=(xP(i)+xP(i+1))/2,my=(yP(data[i].w)+yP(data[i+1].w))/2;
    ctx.quadraticCurveTo(xP(i),yP(data[i].w),mx,my);
  }
  ctx.lineTo(xP(data.length-1),yP(data[data.length-1].w));
  ctx.strokeStyle=lineColor;ctx.lineWidth=2.5;ctx.lineJoin="round";ctx.stroke();

  /* data points */
  data.forEach(function(d,i){
    ctx.beginPath();ctx.arc(xP(i),yP(d.w),3.5,0,Math.PI*2);
    ctx.fillStyle=pointCenter;ctx.fill();
    ctx.strokeStyle=lineStroke;ctx.lineWidth=2;ctx.stroke();
  });

  /* last point highlight */
  var lx=xP(data.length-1),ly=yP(data[data.length-1].w);
  ctx.beginPath();ctx.arc(lx,ly,6,0,Math.PI*2);ctx.fillStyle=dotGlow;ctx.fill();
  ctx.beginPath();ctx.arc(lx,ly,3.5,0,Math.PI*2);ctx.fillStyle=dotFill;ctx.fill();

  /* x-axis labels: first, middle, last */
  ctx.fillStyle=labelColor;ctx.font="9px Inter,system-ui,sans-serif";ctx.textAlign="center";
  [0,Math.floor(data.length/2),data.length-1].forEach(function(i){
    if(data[i]){var s=(data[i].date||"").replace(/^\w+,\s*/,"").replace(/,?\s*\d{4}$/,"");ctx.fillText(s,xP(i),H-6);}
  });
}

/* ── HELPERS ── */
function showToast(msg){
  var t=document.getElementById("toast");if(!t)return;
  t.textContent=msg;t.classList.add("on");
  setTimeout(function(){t.classList.remove("on");},2400);
}
function escHtml(str){return String(str||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");}
function escAttr(str){return String(str||"").replace(/"/g,"&quot;").replace(/'/g,"&#39;");}


/* SAVE WEIGHT ENTRY */
function saveWeightEntry(){
  var wEl=document.getElementById("ci-w");
  var val=wEl?wEl.value.trim():"";
  if(!val||parseFloat(val)<=0){showToast("Enter a weight first");return;}
  logWeight(val);
  persistCI();
  var btn=document.getElementById("log-w-btn");
  if(btn){
    var orig=btn.textContent;
    btn.textContent="\u2713 Saved";
    btn.style.background="var(--aurora2)";
    btn.style.color="#031208";
    setTimeout(function(){
      btn.textContent=orig;
      btn.style.background="var(--aurora2-t)";
      btn.style.color="var(--aurora2)";
    },1800);
  }
  showToast("\u2696\uFE0F Weight logged \u2014 "+parseFloat(val).toFixed(1)+" lbs");
}

/* ── THEME TOGGLE ── */
function applyTheme(theme){
  var icon=document.getElementById("theme-icon");
  if(theme==="light"){
    document.documentElement.setAttribute("data-theme","light");
    if(icon)icon.textContent="\u2600\uFE0F";
    var meta=document.querySelector('meta[name="theme-color"]');
    if(meta)meta.setAttribute("content","#f4f6fb");
  } else {
    document.documentElement.removeAttribute("data-theme");
    if(icon)icon.textContent="\uD83C\uDF19";
    var meta2=document.querySelector('meta[name="theme-color"]');
    if(meta2)meta2.setAttribute("content","#0a0e1a");
  }
}
function toggleTheme(){
  var current=store.get("lift_theme")||"dark";
  var next=current==="dark"?"light":"dark";
  store.set("lift_theme",next);
  applyTheme(next);
  /* redraw chart if history is showing so canvas colors match theme */
  if(activeSec==="history"){
    try{renderHistory();}catch(e){}
  }
}
function initTheme(){
  var saved=store.get("lift_theme")||"dark";
  applyTheme(saved);
}
window.addEventListener("DOMContentLoaded",init);

