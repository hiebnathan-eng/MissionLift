/* ── RENDER DAY ── */
function renderDay(id){
  var day=getDayById(id);if(!day)return;
  var draft=getDraft(id);
  var html="";
  html+='<div class="day-hdr"><div class="day-title">'+escHtml(day.name)+'</div><div class="day-sub">'+escHtml(day.meta)+'</div></div>';
  html+='<div class="warmup-block"><div class="warmup-ttl">\u26A1 Pre-launch warm-up</div>';
  day.warmup.forEach(function(w){html+='<div class="w-item"><span class="w-bullet">\u25B8</span>'+escHtml(w)+'</div>';});
  html+='</div>';
  html+='<div class="eyebrow">Exercises</div>';
  html+='<div class="ex-list">';
  day.exercises.forEach(function(ex,i){html+=buildExCard(id,ex,i,draft);});
  html+='</div>';
  html+='<div class="add-ex-row"><button class="add-ex-btn" onclick="openModal(this.dataset.did)" data-did="'+id+'"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>Add exercise to '+escHtml(day.label)+'</button></div>';
  html+='<div class="save-row"><button class="btn-pri" onclick="saveWorkout(this.dataset.did)" data-did="'+id+'">🚀 Save workout</button><button class="btn-sec" onclick="clearDay(this.dataset.did)" data-did="'+id+'">Clear</button></div>';
  var container=document.getElementById("day-content");
  if(container)container.innerHTML=html;
}

/* ── EXERCISE CARD ── */
function buildExCard(dayId,ex,i,draft){
  var k=dayId+"_"+i;
  var badge=ex.badge||"acc";
  var bLabel={main:"\u2B50 Main",acc:"\uD83D\uDD25 Acc",core:"\uD83D\uDC9C Core",fore:"\u2728 Fore"}[badge]||"Acc";
  var accent={main:"var(--star)",acc:"var(--nova)",core:"var(--pulsar)",fore:"var(--nebula2)"}[badge]||"var(--nova)";
  var isDetOn=!!detPanels[k];
  var isLogOn=!!logPanels[k];
  var d=draft||{};
  var hasData=false;
  for(var s=1;s<=ex.sets;s++){var sd=(d[i]&&d[i][s])||{};if(sd.w||sd.r){hasData=true;break;}}
  var logCls="log-btn"+(isLogOn?" panel-open":(hasData?" has-data":""));
  var logLbl=hasData&&!isLogOn?checkSVG()+"\u2713 Logged":editSVG()+"Log sets";

  var setRows="";
  for(var s=1;s<=ex.sets;s++){
    var sd=(d[i]&&d[i][s])||{};
    var wFl=sd.w?" fl":"";var rFl=sd.r?" fl":"";
    setRows+='<div class="log-row">';
    setRows+='<span class="set-n">'+s+'</span>';
    setRows+='<input class="li'+wFl+'" type="number" inputmode="decimal" id="w_'+dayId+'_'+i+'_'+s+'" placeholder="lbs" value="'+escAttr(sd.w||"")+'" oninput="onInput(\''+dayId+'\','+i+',\''+k+'\')">';
    setRows+='<input class="li'+rFl+'" type="number" inputmode="numeric" id="r_'+dayId+'_'+i+'_'+s+'" placeholder="reps" value="'+escAttr(sd.r||"")+'" oninput="onInput(\''+dayId+'\','+i+',\''+k+'\')">';
    setRows+='<select class="rsel" id="rpe_'+dayId+'_'+i+'_'+s+'" onchange="saveDraft(\''+dayId+'\')"><option value="">RPE</option>';
    [5,6,6.5,7,7.5,8,8.5,9,9.5,10].forEach(function(r){setRows+='<option value="'+r+'"'+(String(sd.rpe)===String(r)?' selected':'')+'>'+r+'</option>';});
    setRows+='</select>';
    setRows+='<input class="note-i" id="n_'+dayId+'_'+i+'_'+s+'" placeholder="note" value="'+escAttr(sd.n||"")+'" onchange="saveDraft(\''+dayId+'\')">';
    setRows+='</div>';
  }

  var h='<div class="ex-card" id="exc_'+k+'">';
  h+='<div class="ex-top"><div class="ex-info">';
  h+='<div class="ex-name">'+escHtml(ex.name)+'</div>';
  h+='<div class="ex-tl" style="color:'+accent+'">'+escHtml(ex.target||"")+'</div>';
  h+='<div class="tag-row"><span class="mtag mt-p">\uD83C\uDFAF '+escHtml(ex.primary||"—")+'</span>';
  if(ex.secondary&&ex.secondary!=="—")h+='<span class="mtag mt-s">'+escHtml(ex.secondary)+'</span>';
  h+='</div></div>';
  h+='<div class="badges"><span class="badge b-'+badge+'">'+bLabel+'</span></div>';
  h+='</div>';
  h+='<div class="ex-acts">';
  h+='<button class="act-btn'+(isDetOn?' on':'')+'" id="detbtn_'+k+'" onclick="toggleDet(this.dataset.k,this)" data-k="'+k+'"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>How to</button>';
  h+='<button class="'+logCls+'" id="logbtn_'+k+'" onclick="toggleLog(this.dataset.k,this.dataset.did,+this.dataset.ei,this)" data-k="'+k+'" data-did="'+dayId+'" data-ei="'+i+'">'+logLbl+'</button>';
  h+='<button class="del-btn" onclick="deleteExercise(this.dataset.did,+this.dataset.ei)" data-did="'+dayId+'" data-ei="'+i+'"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6M9 6V4h6v2"/></svg></button>';
  h+='</div>';
  h+='<div class="det-panel'+(isDetOn?" on":"")+'" id="det_'+k+'">';
  h+='<div class="how-box"><div class="how-p">\uD83C\uDFAF Primary: '+escHtml(ex.primary||"—")+'</div>'+escHtml(ex.how||"Perform with controlled form.")+'</div>';
