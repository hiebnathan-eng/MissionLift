function toggleDet(k,btn){
  detPanels[k]=!detPanels[k];
  var p=document.getElementById("det_"+k);if(p)p.classList.toggle("on",detPanels[k]);
  if(btn)btn.classList.toggle("on",detPanels[k]);
}

function toggleLog(k,dayId,exIdx,btn){
  logPanels[k]=!logPanels[k];
  var p=document.getElementById("log_"+k);if(p)p.classList.toggle("on",logPanels[k]);
  var day=getDayById(dayId);
  var ex=day&&day.exercises[exIdx];
  var hasData=false;
  if(ex){for(var s=1;s<=ex.sets;s++){var wEl=document.getElementById("w_"+dayId+"_"+exIdx+"_"+s);var rEl=document.getElementById("r_"+dayId+"_"+exIdx+"_"+s);if((wEl&&wEl.value)||(rEl&&rEl.value)){hasData=true;break;}}}
  if(btn){
    if(logPanels[k]){btn.className="log-btn panel-open";btn.innerHTML=editSVG()+"Close";}
    else if(hasData){btn.className="log-btn has-data";btn.innerHTML=checkSVG()+"\u2713 Logged";}
    else{btn.className="log-btn";btn.innerHTML=editSVG()+"Log sets";}
  }
}

/* ── ADD SET ── */
function addSet(dayId,exIdx){
  saveDraft(dayId);
  var day=getDayById(dayId);if(!day)return;
  day.exercises[exIdx].sets=(day.exercises[exIdx].sets||3)+1;
  saveDays();
  logPanels[dayId+"_"+exIdx]=true;
  renderDay(dayId);
}

/* ── SAVE WORKOUT ── */
function saveWorkout(dayId){
  saveDraft(dayId);
  var day=getDayById(dayId);if(!day)return;
  var draft=getDraft(dayId);
  var ci=getCI();
  var entry={dayId:dayId,dayName:day.name,date:new Date().toLocaleDateString("en-US",{weekday:"short",month:"short",day:"numeric",year:"numeric"}),ts:Date.now(),weight:ci.w||"",mood:ci.m||"",
    exercises:day.exercises.map(function(ex,i){return{name:ex.name,primary:ex.primary||"",sets:draft[i]||{}};})
  };
  var logs=getLogs();logs.unshift(entry);saveLogs(logs);
  initStreak();showToast("\uD83D\uDE80 Workout saved!");
}

function clearDay(dayId){
  store.sdel("lift_draft_"+dayId);
  logPanels={};
  renderDay(dayId);
}

function deleteExercise(dayId,i){
  var day=getDayById(dayId);if(!day)return;
  if(!confirm('Remove "'+day.exercises[i].name+'" from '+day.label+'?'))return;
  day.exercises.splice(i,1);saveDays();renderDay(dayId);showToast("Removed");
}

/* ── MODAL ── */
function openModal(dayId){
  modalDay=dayId;
  ["m-name","m-target","m-prime","m-sec","m-how"].forEach(function(id){var el=document.getElementById(id);if(el)el.value="";});
  var s=document.getElementById("m-sets");if(s)s.value="";
  var b=document.getElementById("m-badge");if(b)b.value="acc";
  var ov=document.getElementById("overlay");if(ov)ov.classList.add("on");
  setTimeout(function(){var nm=document.getElementById("m-name");if(nm)nm.focus();},120);
}
function closeOverlay(e){if(e.target===document.getElementById("overlay"))closeOverlayDirect();}
function closeOverlayDirect(){var ov=document.getElementById("overlay");if(ov)ov.classList.remove("on");}
function addExercise(){
  var nameEl=document.getElementById("m-name");
  var name=(nameEl?nameEl.value:"").trim();
  if(!name){if(nameEl)nameEl.focus();return;}
  var day=getDayById(modalDay);if(!day)return;
  var badge=(document.getElementById("m-badge")||{}).value||"acc";
  var sets=parseInt((document.getElementById("m-sets")||{}).value)||3;
  var target=((document.getElementById("m-target")||{}).value||"3\xD710").trim();
  var prime=((document.getElementById("m-prime")||{}).value||"\u2014").trim();
  var sec=((document.getElementById("m-sec")||{}).value||"").trim();
  var how=((document.getElementById("m-how")||{}).value||"Perform with controlled form.").trim();
  day.exercises.push({name:name,badge:badge,sets:sets,target:target,primary:prime,secondary:sec,how:how});
  saveDays();closeOverlayDirect();renderDay(modalDay);showToast("Exercise added \u2713");
}

